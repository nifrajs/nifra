node_modules/
dist/
coverage/
*.tgz
*.tsbuildinfo
.astro/
.wrangler/
.DS_Store
*.log
.env
.env.*
!.env.example
.fwtmp
# Generated by @nifrajs/web/vite's dev server (the codegen'd client entry written at the app root).
.nifra-vite-entry.tsx
bench/size/.tmp
# In-workspace temp app dirs created by build integration tests (cleaned in afterEach; this guards a
# crashed run from leaving an uncommitted dir). They must live in-tree so @nifrajs/* resolves.
packages/web/test/.tmp-*

# Internal working docs (planning, design, audit) — kept on disk for local reference, never committed.
# (README.md stays tracked.)
/AUDIT*.md
/*FEEDBACK*.md

# Benchmark RESULTS — generated locally, never committed (numbers move with machine load; see
# bench/README.md). The benchmark CODE under bench/ stays tracked.
/BENCHMARKS.md
/SSR-BENCHMARKS.md
/PLAN.md
/*-PLAN.md
/*-PARITY.md
/PHASE*.md
/FRONTEND.md
/FRONTEND-F*.md
/ADAPTERS.md
/RUNTIMES.md
/SITE.md
/TYPED-ENV.md
/QUERY-CACHE.md
/*-REVIEW.md
/WEBSOCKETS*.md
bench/**/*.md
!bench/README.md
/plans

# Local editor/agent tooling — machine-specific (absolute paths, local settings); never committed.
.claude/launch.json
.claude/settings.local.json
.code-review-graph/

# check:docs snippet sandbox (transient) — lives under site/ so workspace @nifrajs/* symlinks resolve
site/.tmp-doc-check

# release tooling kept local, not published in the public repo
scripts/check-publish.ts
