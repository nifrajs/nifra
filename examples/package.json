{
  "name": "@nifrajs/examples",
  "version": "1.13.0",
  "type": "module",
  "private": true,
  "description": "Runnable, type-checked examples for nifra. Not published.",
  "scripts": {
    "routing-solid:build": "bun run routing-solid/build.ts",
    "routing-solid:dev": "bun --preload routing-solid/ssr-preload.ts routing-solid/dev.ts",
    "routing-solid:start": "bun --preload routing-solid/ssr-preload.ts routing-solid/server.ts",
    "routing-react:build": "bun run routing-react/build.ts",
    "routing-react:dev": "bun run routing-react/dev.ts",
    "routing-react:start": "bun run routing-react/server.ts",
    "hmr-react:dev": "bun run hmr-react/dev.ts",
    "hmr-preact:dev": "bun run hmr-preact/dev.ts",
    "hmr-vue:dev": "bun --preload hmr-vue/ssr-preload.ts hmr-vue/dev.ts",
    "hmr-solid:dev": "bun --preload hmr-solid/ssr-preload.ts hmr-solid/dev.ts",
    "hmr-svelte:dev": "bun --preload hmr-svelte/ssr-preload.ts hmr-svelte/dev.ts",
    "cli-react:dev": "cd cli-react && nifra dev",
    "cli-react:build": "cd cli-react && nifra build",
    "cli-react:start": "cd cli-react && nifra start",
    "cli-vue:dev": "cd cli-vue && nifra dev",
    "cli-vue:build": "cd cli-vue && nifra build",
    "cli-vue:start": "cd cli-vue && nifra start",
    "mcp-app:start": "bun run mcp-app/server.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@mdx-js/rollup": "^3",
    "@nifrajs/auth": "workspace:*",
    "@nifrajs/cli": "workspace:*",
    "@nifrajs/client": "workspace:*",
    "@nifrajs/content": "workspace:*",
    "@nifrajs/core": "workspace:*",
    "@nifrajs/deno": "workspace:*",
    "@nifrajs/i18n": "workspace:*",
    "@nifrajs/image": "workspace:*",
    "@nifrajs/mcp": "workspace:*",
    "@nifrajs/middleware": "workspace:*",
    "@nifrajs/node": "workspace:*",
    "@nifrajs/schema": "workspace:*",
    "@nifrajs/web": "workspace:*",
    "@nifrajs/web-preact": "workspace:*",
    "@nifrajs/web-react": "workspace:*",
    "@nifrajs/web-solid": "workspace:*",
    "@nifrajs/web-svelte": "workspace:*",
    "@nifrajs/web-vue": "workspace:*",
    "@nifrajs/workers": "workspace:*",
    "@preact/preset-vite": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "preact": "^10.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solid-js": "^1.9.3",
    "svelte": "^5.0.0",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.10.0",
    "vue": "^3.5.0"
  }
}
