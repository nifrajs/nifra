{
  "name": "@nifrajs/budget",
  "version": "1.10.0",
  "description": "Portable request deadlines for Nifra — monotonic remaining time, absolute wire propagation, child reserves, and deterministic clocks.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "deadline",
    "timeout",
    "abort-signal",
    "distributed-systems",
    "edge"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nifrajs/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/budget"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
