{
  "name": "@nifrajs/web-svelte",
  "version": "1.11.0",
  "description": "Svelte 5 render adapter for @nifrajs/web — SSR + hydration + the .svelte compiler Bun-plugin.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "edge",
    "ssr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "bun": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./plugin": {
      "bun": "./src/plugin.ts",
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./await": {
      "types": "./dist/Await.svelte.d.ts",
      "bun": "./src/Await.svelte",
      "svelte": "./dist/Await.svelte",
      "default": "./dist/Await.svelte"
    },
    "./fetcher": {
      "bun": "./src/fetcher.ts",
      "types": "./dist/fetcher.d.ts",
      "default": "./dist/fetcher.js"
    },
    "./query": {
      "bun": "./src/query.ts",
      "types": "./dist/query.d.ts",
      "default": "./dist/query.js"
    },
    "./image": {
      "types": "./dist/Image.svelte.d.ts",
      "bun": "./src/Image.svelte",
      "svelte": "./dist/Image.svelte",
      "default": "./dist/Image.svelte"
    },
    "./content": {
      "types": "./dist/Content.svelte.d.ts",
      "bun": "./src/Content.svelte",
      "svelte": "./dist/Content.svelte",
      "default": "./dist/Content.svelte"
    },
    "./i18n": {
      "bun": "./src/i18n.ts",
      "types": "./dist/i18n.d.ts",
      "default": "./dist/i18n.js"
    },
    "./mdx": {
      "bun": "./src/mdx.ts",
      "types": "./dist/mdx.d.ts",
      "default": "./dist/mdx.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist && cp src/*.svelte dist/ && cp src/*.svelte.d.ts dist/"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nifrajs/i18n": "workspace:*",
    "@nifrajs/image": "workspace:*",
    "@nifrajs/web": "workspace:*"
  },
  "peerDependencies": {
    "mdsvex": "^0.12",
    "svelte": "^5.3.0"
  },
  "peerDependenciesMeta": {
    "mdsvex": {
      "optional": true
    }
  },
  "devDependencies": {
    "svelte": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/web-svelte"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
