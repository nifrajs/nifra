{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Frontend adapter: needs DOM types (client mount/hydrate cast the container to `Element`).
    // Excluded from the root typecheck; checked via the `typecheck` script.
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@nifrajs/web": ["../web/src/index.ts"],
      "@nifrajs/core": ["../core/src/index.ts"],
      "@nifrajs/core/reflection": ["../core/src/reflection.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
