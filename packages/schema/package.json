{
  "name": "@nifrajs/schema",
  "version": "0.1.0-alpha.1",
  "description": "Built-in schema builder `t` — TypeBox-backed (free JSON Schema + compiled validators), implements Standard Schema so nifra routes validate it natively.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "edge",
    "ssr",
    "validation",
    "typebox",
    "json-schema",
    "standard-schema"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openapi": {
      "bun": "./src/openapi.ts",
      "types": "./dist/openapi.d.ts",
      "default": "./dist/openapi.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "comment:sideEffects": "formats.ts registers string formats into TypeBox's global FormatRegistry on import — that file must not be tree-shaken away, so it (not the package) is marked side-effectful.",
  "sideEffects": [
    "./src/formats.ts",
    "./dist/formats.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "peerDependencies": {
    "@nifrajs/core": "workspace:*"
  },
  "devDependencies": {
    "@nifrajs/core": "workspace:*",
    "@nifrajs/test-utils": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
