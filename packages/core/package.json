{
  "name": "@nifrajs/core",
  "version": "1.10.0",
  "description": "Bun-native, contract-first HTTP framework — the router, server, and route descriptor.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "edge",
    "ssr",
    "http",
    "router",
    "api",
    "standard-schema",
    "typesafe",
    "backend"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ws": {
      "bun": "./src/ws.ts",
      "types": "./dist/ws.d.ts",
      "default": "./dist/ws.js"
    },
    "./reflection": {
      "bun": "./src/reflection.ts",
      "types": "./dist/reflection.d.ts",
      "default": "./dist/reflection.js"
    },
    "./diff": {
      "bun": "./src/diff.ts",
      "types": "./dist/diff.d.ts",
      "default": "./dist/diff.js"
    },
    "./assurance": {
      "bun": "./src/assurance.ts",
      "types": "./dist/assurance.d.ts",
      "default": "./dist/assurance.js"
    },
    "./capabilities": {
      "bun": "./src/capabilities.ts",
      "types": "./dist/capabilities.d.ts",
      "default": "./dist/capabilities.js"
    },
    "./budget": {
      "bun": "./src/budget.ts",
      "types": "./dist/budget.d.ts",
      "default": "./dist/budget.js"
    },
    "./idempotency": {
      "bun": "./src/idempotency.ts",
      "types": "./dist/idempotency.d.ts",
      "default": "./dist/idempotency.js"
    },
    "./manifest": {
      "bun": "./src/manifest.ts",
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "./src/ws.ts",
    "./dist/ws.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@nifrajs/test-utils": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
