{
  "name": "@nifrajs/mock",
  "version": "1.6.0",
  "description": "Contract-based mock server — reads route schemas and generates fake responses.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nifrajs/core": "workspace:*"
  }
}
