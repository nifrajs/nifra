{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Frontend adapter: needs DOM types (client hydrate casts the container to `Element`).
    // Excluded from the root typecheck; checked via the `typecheck` script.
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@nifrajs/web": ["../web/src/index.ts"],
      "@nifrajs/web/islands": ["../web/src/islands.ts"],
      "@nifrajs/core": ["../core/src/index.ts"],
      "@nifrajs/core/reflection": ["../core/src/reflection.ts"],
      "@nifrajs/i18n": ["../i18n/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
