{
  "name": "@nifrajs/testing",
  "version": "2.1.0",
  "description": "Contract-derived adversarial tests, runtime-matrix response conformance, and cookie-aware in-process sessions for Nifra apps.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "testing",
    "ssr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./certification": {
      "bun": "./src/certification.ts",
      "types": "./dist/certification.d.ts",
      "default": "./dist/certification.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "dependencies": {
    "@nifrajs/client": "workspace:*",
    "@nifrajs/core": "workspace:*",
    "@nifrajs/mock": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
