{
  "name": "@nifrajs/node",
  "version": "1.9.0",
  "description": "Run a nifra app on Node's http server — a Request<->stream adapter with a graceful stop().",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "edge",
    "ssr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "peerDependencies": {
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
