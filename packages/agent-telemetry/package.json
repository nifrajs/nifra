{
  "name": "@nifrajs/agent-telemetry",
  "version": "1.11.0",
  "description": "Agent telemetry plugin — child spans for AI tool calls on /_nifra/tool/* and MCP endpoints.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nifrajs/otel": "workspace:*"
  },
  "peerDependencies": {
    "@nifrajs/core": "workspace:^"
  },
  "devDependencies": {
    "@nifrajs/core": "workspace:*"
  }
}
