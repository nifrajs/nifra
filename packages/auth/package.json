{
  "name": "@nifrajs/auth",
  "version": "1.6.0",
  "description": "Session primitives for nifra — signed-cookie + server-store sessions, CSRF, and route guards. Bring your own identity (Better Auth / Lucia / OAuth); nifra owns the session.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "full-stack",
    "edge",
    "ssr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@nifrajs/core": "workspace:^"
  },
  "devDependencies": {
    "@nifrajs/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
