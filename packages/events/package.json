{
  "name": "@nifrajs/events",
  "version": "1.12.0",
  "description": "Portable, versioned event contracts — a typed, transport-agnostic event envelope validated by any Standard Schema.",
  "keywords": [
    "bun",
    "typescript",
    "nifra",
    "web-framework",
    "events",
    "event-contract",
    "versioning",
    "standard-schema",
    "edge"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run ../../scripts/fix-dts.ts dist"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@nifrajs/core": "workspace:^"
  },
  "devDependencies": {
    "@nifrajs/core": "workspace:*",
    "@nifrajs/schema": "workspace:*",
    "@nifrajs/test-utils": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nifrajs/nifra.git",
    "directory": "packages/events"
  },
  "bugs": {
    "url": "https://github.com/nifrajs/nifra/issues"
  },
  "homepage": "https://github.com/nifrajs/nifra#readme"
}
